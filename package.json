{
  "name": "astra",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "set \"ELECTRON_RUN_AS_NODE=\" && set \"VITE_DEV_SERVER_URL=http://localhost:5173\" && wait-on http://localhost:5173 && electron .",
    "diagnose:electron": "set \"ELECTRON_RUN_AS_NODE=\" && electron scripts/electron-diagnostic.js",
    "diagnose:electron-app": "set \"ELECTRON_RUN_AS_NODE=\" && set \"ASTRA_ELECTRON_APP_DIAGNOSTIC=1\" && electron .",
    "diagnose:behavior:build": "set \"ELECTRON_RUN_AS_NODE=\" && electron scripts/electron-behavior-check.js --mode=build",
    "diagnose:behavior:dev": "set \"ELECTRON_RUN_AS_NODE=\" && set \"VITE_DEV_SERVER_URL=http://localhost:5173\" && electron scripts/electron-behavior-check.js --mode=dev",
    "start": "set \"ELECTRON_RUN_AS_NODE=\" && electron .",
    "build": "vite build",
    "lint": "eslint . --max-warnings=0"
  },
  "dependencies": {
    "concurrently": "^9.0.0",
    "electron": "41.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.13",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
